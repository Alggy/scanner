# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NewsAPI — https://newsapi.org (free tier: 100 req/day) — optional
NEWSAPI_KEY=your_newsapi_key_here

# Database path — leave unset locally (defaults to scanner.db in project root)
# On Render this is set automatically via render.yaml to /data/scanner.db
# DATABASE_PATH=/data/scanner.db
